# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Arno Pro (Adobe lisanslı — dağıtılamaz). Yalnızca yerel/kişisel kullanım için
# public/fonts'a konur; depoya ve yayınlanan sürüme GİRMEMELİ. Yoksa pdf.ts
# otomatik olarak ücretsiz Source Serif 4'e düşer.
/public/fonts/Arno-*.otf

# typescript
*.tsbuildinfo
next-env.d.ts
